# TinyInsta — environment variables. Copy to `.env`: `cp .env.example .env`
# DEVELOPMENT values — never use these as-is in production.

# --- Django -----------------------------------------------------------------
DJANGO_DEBUG=true
DJANGO_SECRET_KEY=dev-insecure-change-me

# --- Postgres (shared instance, one database per service) -------------------
POSTGRES_USER=tinyinsta
POSTGRES_PASSWORD=tinyinsta

# --- Keycloak (OIDC) --------------------------------------------------------
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin
# Issuer as seen by the BROWSER (hence localhost), not the Docker network.
OIDC_ISSUER=http://localhost:8080/realms/tinyinsta
# OIDC_AUDIENCE=        # leave empty to skip audience checks; set it AND add a Keycloak audience mapper to enable

# --- Neo4j ------------------------------------------------------------------
NEO4J_USER=neo4j
NEO4J_PASSWORD=tinyinsta

# --- MinIO / S3 -------------------------------------------------------------
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=media
# Media READ URLs are served through the caching CDN (nginx in front of MinIO),
# routed by Traefik on /cdn. Uploads (presigned PUT) still go straight to MinIO.
# Set empty / to http://localhost:9000 to bypass the CDN.
S3_CDN_URL=http://localhost/cdn

# --- Bus consumer dedupe & resilience ---------------------------------------
# Durable, cross-replica idempotency store for event consumers (RedisDedupeStore).
# Dedicated Redis DB, isolated from each service's own data; keys are namespaced
# per service so all consumers can share it.
DEDUPE_REDIS_URL=redis://redis:6379/0
# Bounded in-process retry before a message is routed to the dead-letter topic
# (dlq.<group_id>). BUS_RETRY_BACKOFF is the base delay in seconds (exponential).
BUS_MAX_ATTEMPTS=3
BUS_RETRY_BACKOFF=0.5
# Validate every published event against its registered schema (set 0 to disable).
BUS_VALIDATE=1

# --- Rate limiting (per-user, on top of Traefik's per-IP limit) -------------
RATELIMIT_ENABLED=1
RATELIMIT_USER_RATE=120/min
# Defaults to DEDUPE_REDIS_URL if unset.
# RATELIMIT_REDIS_URL=redis://redis:6379/0

# --- Feed ranking (ranking-svc) ---------------------------------------------
# When true, hometimeline-svc re-ranks each page via ranking-svc (else chronological).
RANKING_ENABLED=true
RANK_W_RECENCY=1.0
RANK_W_ENGAGEMENT=0.6
RANK_W_AFFINITY=0.8
RANK_RECENCY_HALF_LIFE_H=6

# --- Cassandra (messaging-svc / direct messages) ----------------------------
CASSANDRA_HOSTS=cassandra
CASSANDRA_PORT=9042
CASSANDRA_KEYSPACE=messaging
CASSANDRA_REPLICATION=1

# --- Resource tuning --------------------------------------------------------
# gunicorn workers per HTTP service. 1 keeps the whole stack within a ~6 GB
# Docker VM; raise to 2+ if you give Docker Desktop more RAM (8 GB recommended).
WEB_CONCURRENCY=1

# --- Observability ----------------------------------------------------------
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin

# --- Frontend (Next.js) -----------------------------------------------------
# The frontend talks to Traefik (http://localhost) for /api and /ws.
NEXT_PUBLIC_API_URL=http://localhost/api
NEXT_PUBLIC_WS_URL=ws://localhost/ws
NEXT_PUBLIC_KEYCLOAK_URL=http://localhost:8080
NEXT_PUBLIC_KEYCLOAK_REALM=tinyinsta
NEXT_PUBLIC_KEYCLOAK_CLIENT_ID=tinyinsta-frontend
