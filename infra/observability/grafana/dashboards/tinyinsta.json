{
  "annotations": { "list": [] },
  "editable": true,
  "schemaVersion": 39,
  "title": "TinyInsta — Services",
  "tags": ["tinyinsta"],
  "time": { "from": "now-15m", "to": "now" },
  "refresh": "10s",
  "templating": { "list": [] },
  "panels": [
    {
      "id": 1,
      "title": "Request rate (req/s) by service",
      "type": "timeseries",
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (service) (rate(django_http_requests_before_middlewares_total[1m]))",
          "legendFormat": "{{service}}"
        }
      ]
    },
    {
      "id": 2,
      "title": "Latency p95 (s) by service",
      "type": "timeseries",
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (service, le) (rate(django_http_requests_latency_seconds_by_view_method_bucket[5m])))",
          "legendFormat": "{{service}}"
        }
      ]
    },
    {
      "id": 3,
      "title": "5xx responses (req/s) by service",
      "type": "timeseries",
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 9 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (service) (rate(django_http_responses_total_by_status_total{status=~\"5..\"}[1m]))",
          "legendFormat": "{{service}}"
        }
      ]
    }
  ]
}
